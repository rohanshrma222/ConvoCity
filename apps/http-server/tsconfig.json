{
    "extends": "@repo/typescript-config/base.json",
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",
        "baseUrl": ".",
        "module": "Node16",
        "moduleResolution": "Node16",
        "esModuleInterop": true,
        "paths": {
            "zod": ["./node_modules/zod/index.d.ts"],
            "zod/v4": ["./node_modules/zod/v4/index.d.ts"]
        },
        "resolveJsonModule": true,
        "strict": true,
        "skipLibCheck": true
    },
    "include": ["src/**/*"]
}
